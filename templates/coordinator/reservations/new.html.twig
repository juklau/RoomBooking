{% extends 'base.html.twig' %}

{% block title %}Créer une réservation — Coordinator RoomBooking{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/rooms.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/classes.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/coordinator.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid px-4 py-3 mt-3">

    {# ---- Header ---- #}
    <div class="dashboard-header">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                 <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="badge-coordinator">Coordinateur</span>
                </div>
                <div class="d-flex align-items-center gap-2 mb-1">
                    <a href="{{ path('app_coordinator_dashboard') }}" class="breadcrumb-link-coordinator">Dashboard</a>
                    <span class="breadcrumb-sep">›</span>

                    <a href="{{ path('app_coordinator_rooms') }}" class="breadcrumb-link-coordinator">Salles</a>
                    <span class="breadcrumb-sep">›</span>

                    <span class="breadcrumb-current">Nouvelle réservation</span>
                </div>
                <h1>Créer une réservation</h1>
                <p>Réservez une salle pour vous-même ou pour un de vos étudiants</p> 
            </div>
        </div>
    </div>

    {# ---- Formulaire ---- #}
    <div class="row justify-content-center">
        <div class="col-lg-6 mt-3">
            <div class="form-card shadow">

                {{ form_start(form) }}

                {# marquer classe comme rendu pour éviter le rendu automatique par form_end #}
                {% do form.classe.setRendered() %}

                    {# Salle #}
                    <div class="form-field">
                        {{ form_label(form.room) }}
                        {{ form_widget(form.room) }}
                        {{ form_errors(form.room) }}
                    </div>

                    {# Date #}
                    <div class="form-field">
                        {{ form_label(form.date) }}
                        {{ form_widget(form.date) }}
                        {{ form_errors(form.date) }}
                    </div>

                    {# Heures de début et fin #}
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-field">
                                {{ form_label(form.startTime) }}
                                {{ form_widget(form.startTime) }}
                                {{ form_errors(form.startTime) }}
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-field">
                                {{ form_label(form.endTime) }}
                                {{ form_widget(form.endTime) }}
                                {{ form_errors(form.endTime) }}
                            </div>
                        </div>
                    </div>

                    <div class="field-hint mb-4 text-center">
                        🕐 Créneaux disponibles de 08:00 à 20:00, par intervalles de 30 minutes.
                    </div>

                    {# Bénéficiaire => uniquement les étudiants #}
                    <div class="form-field">
                        {{ form_label(form.beneficiary) }}
                        {{ form_widget(form.beneficiary) }}
                        {{ form_errors(form.beneficiary) }}
                        <div class="field-hint mt-3">
                            Laissez vide pour réserver en votre propre nom.
                            Seuls vos étudiants sont disponibles.
                        </div>
                    </div>

                    {# Classe #}
                    <div class="form-field">
                        <label for="classe-select">Classe concernée</label>
                        <select name="coordinator_reservation[classe]" id="classe-select" class="form-select">
                            <option value="">-- Sélectionnez d'abord un bénéficiaire --</option>
                        </select>
                        <div class="field-hint" id="classe-hint">
                            Sélectionnez la classe concernée par cette réservation.
                        </div>
                    </div>

                    {# Boutons #}
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn-coordinator-details flex-fill text-center">
                             Réserver
                        </button>
                        <a href="{{ path('app_coordinator_rooms') }}"
                           class="btn-action-secondary flex-fill text-center text-decoration-none">
                            Annuler
                        </a>
                    </div>

                {{ form_end(form) }}

            </div>

            <div class="form-note mt-4">
                Trois vérifications sont effectuées automatiquement :
                la date doit être dans le futur, l'heure de fin doit être après l'heure de début,
                et la salle doit être libre sur ce créneau.
            </div>
        </div>
    </div>

</div>
{% endblock %}

{% block javascripts %}
<script>
    const usersData = {{ usersData|json_encode|raw }};
    const selectedBeneficiaryId = {{ selectedBeneficiary ?? 'null' }};
</script>
<script src="{{ asset('js/coordinator_reservation.js') }}"></script>
{% endblock %}
