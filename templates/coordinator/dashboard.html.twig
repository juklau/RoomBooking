{% extends 'base.html.twig' %}

{% block title %}Dashboard Coordinateur — RoomBooking{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin.css')}}">
    <link rel="stylesheet" href="{{ asset('styles/coordinator.css')}}"> 
{% endblock %}

{% block body %}

<div class="container-fluid px-4">

    {# ---- Header ---- #}
    <div class="dashboard-header">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="badge-coordinator">Coordinateur</span>
                </div>
                <h1>Bonjour, {{ app.user.firstname ?? app.user.userIdentifier }} 👋</h1>
                {# date('d MMMM Y') #}
                <p>Voici un aperçu de vos classes et réservations - {{ 'now'|date("d/m/Y","Europe/Paris") }}</p>
            </div>
        </div>
    </div>

    {# ---- Stats ---- #}
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card text-center flex-column d-flex shadow">
                <div class="stat-icon mx-auto" id="stat-icon-classes">🎓</div>
                <div class="stat-value">{{ stats.my_classes }}</div>
                <div class="stat-label">Mes Classes</div>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="stat-card text-center flex-column d-flex shadow"> 
                <div class="stat-icon mx-auto" id="stat-icon-students">👨‍🎓</div>
                <div class="stat-value">{{ stats.my_students }}</div>
                <div class="stat-label">Mes Étudiants</div>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="stat-card text-center flex-column d-flex shadow">
                <div class="stat-icon mx-auto" id="stat-icon-rooms" >🏫</div>
                <div class="stat-value">{{ stats.rooms }}</div>
                <div class="stat-label">Salles dispo</div>
            </div>
        </div>

        <div class="col-6 col-md-3">
            <div class="stat-card text-center flex-column d-flex shadow">
                <div class="stat-icon mx-auto" id="stat-icon-reservations">📅</div>
                <div class="stat-value">{{ stats.reservations }}</div>
                <div class="stat-label">Mes Réservations</div>
            </div>
        </div>
    </div>

    <div class="row g-4">

        {# ---- Colonne gauche ---- #}
        <div class="col-lg-8">

            {# Mes réservations à venir #}
            <div class="mb-4">
                <div class="section-title d-flex align-items-center">📅 Mes prochaines réservations</div>
                <div class="reservations-table shadow">
                    <table class="table table-borderless mb-0 text-center">
                        <thead>
                            <tr>
                                <th>Salle</th>
                                <th>Début</th>
                                <th>Fin</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% if myReservations is empty %}
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">
                                        Aucune réservation à venir
                                    </td>
                                </tr>
                            {% else %}
                                {% for res in myReservations %}
                                    <tr onclick="window.location='{{ path('app_coordinator_rooms') }}'" class="rows-onclick">
                                        <td><strong>{{ res.room.name }}</strong></td>
                                        <td>
                                            {% set isToday = res.reservationStart|date('Y-m-d', 'Europe/Paris') == 'now'|date('Y-m-d', 'Europe/Paris') %}
                                            <span class="status-dot {{ isToday ? 'status-today' : 'status-upcoming' }}"></span>
                                            {{ res.reservationStart|date('d/m/Y H:i', 'Europe/Paris') }}
                                        </td>
                                        <td>{{ res.reservationEnd|date('d/m/Y H:i', 'Europe/Paris') }}</td>
                                        <td>
                                            {# <a href="#" class="btn btn-sm btn-outline-danger">Annuler</a> #}
                                            {{ include('partials/_cancel_reservation_coordinator.html.twig', { reservation: res }) }}
                                        </td>
                                    </tr>
                                {% endfor %}
                            {% endif %}
                        </tbody>
                    </table>
                </div>
            </div>

            {# Mes classes et étudiants #}
            <div class="mb-4">
                <div class="section-title d-flex align-items-center">🎓 Mes classes</div>
                {% if myClasses is empty %}
                    <p class="text-muted small">Aucune classe assignée.</p>
                {% else %}
                    {% for classe in myClasses %}
                        <div class="class-block shadow mb-3">
                            <div class="class-block-header d-flex align-items-center justify-content-between">
                                <div>
                                    <span class="class-block-name">{{ classe.name }}</span>
                                    <span class="class-block-count ms-2">
                                        {{ classe.students|length }} étudiant{{ classe.students|length > 1 ? 's' : '' }}
                                    </span>
                                </div>
                                <div class="d-flex gap-2">
                                    <a href="{{ path('app_coordinator_classe_show', {id: classe.id}) }}" class="btn btn-sm btn-outline-secondary" id="btn-details-classe">Voir détail →</a>
                                    <a href="{{ path('app_coordinator_student_add', {id: classe.id}) }}" class="btn btn-sm btn-coordinator">+ Étudiant</a>
                                </div>
                            </div>

                            {% if classe.students is not empty %}
                                <div class="class-block-students">
                                    <div class="row g-2 mt-1">
                                        {% for student in classe.students %}
                                            <div class="col-md-6">
                                                <div class="student-row d-flex align-items-center justify-content-between">
                                                    <div class="d-flex align-items-center gap-2">
                                                        <div class="student-avatar">
                                                            {{ student.user.firstname|first|upper }}{{ student.user.lastname|first|upper }}
                                                        </div>
                                                        <div>
                                                            <div class="student-name">
                                                                {{ student.user.firstname }} {{ student.user.lastname }}
                                                            </div>
                                                            <div class="student-email">{{ student.user.email }}</div>
                                                        </div>
                                                    </div>
                                                    {# <a href="#" class="btn btn-sm btn-outline-danger btn-xs">✕</a> #}
                                                    {{ include('partials/_remove_student_classe.html.twig', { student: student, classe: classe }) }}
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                {% endif %}
            </div>

        </div>

        {# ---- Colonne droite ---- #}
        <div class="col-lg-4">

            {# Actions rapides #}
            <div class="mb-4">
                <div class="section-title d-flex align-items-center">⚡ Actions rapides</div>
                <div class="d-flex flex-column gap-2">
                    <a href="{{ path('app_coordinator_rooms') }}" class="action-btn text-decoration-none d-flex align-items-center">
                        <span class="action-icon d-flex align-items-center justify-content-center" id="action-icon-rooms">🏫</span>
                        Réserver une salle
                    </a>

                    {# redirection vers la liste des classes => pour choisir sa classe, car il n'y a pas classe.id ici !!! #}
                    <a href="{{ path('app_coordinator_classes') }}" class="action-btn text-decoration-none d-flex align-items-center">
                        <span class="action-icon d-flex align-items-center justify-content-center" id="action-icon-students">👨‍🎓</span>
                        Ajouter un étudiant
                    </a>
                    <a href="{{ path('app_coordinator_classes') }}" class="action-btn text-decoration-none d-flex align-items-center">
                        <span class="action-icon d-flex align-items-center justify-content-center" id="action-icon-classes">🎓</span>
                        Consulter mes classes
                    </a>
                </div>
            </div>

            {# Salles disponibles #}
            <div class="mb-4">
                <div class="section-title d-flex align-items-center">🏫 Salles disponibles</div>
                <div class="d-flex flex-column gap-2">
                    {% for room in rooms %}
                        <div class="room-row d-flex align-items-center justify-content-between shadow">
                            <div>
                                <div class="room-row-name">{{ room.name }}</div>
                                <div class="room-row-capacity">👥 {{ room.capacity }} places</div>
                            </div>
                            <a href="{{ path('app_coordinator_reservation_new', {room: room.id}) }}" class="btn btn-sm btn-coordinator">Réserver</a>
                        </div>
                    {% else %}
                        <p class="text-muted small">Aucune salle disponible.</p> 
                    {% endfor %}
                </div>
            </div>

        </div>
    </div>

</div>
{% endblock %}