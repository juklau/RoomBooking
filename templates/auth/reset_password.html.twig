{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe — RoomBooking{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/login.css') }}">
{% endblock %}

{% block body %}
<div class="login-page d-flex justify-content-center align-items-center">
    <div class="login-card">

       
        <h1 class="mb-4 mt-3 text-center">🔒 Nouveau mot de passe</h1>
        <p class="subtitle text-center">Choisissez un mot de passe sécurisé</p>
       

        {# Flash messages #}
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : 'success' }} mb-3">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {{ form_start(form) }}

            <div class="form-field">
                <div class="label-reset-password">
                    {{ form_label(form.password.first) }}
                </div>

                <div class="input-group input-group-password">
                    {{ form_widget(form.password.first) }}
                    <button type="button"
                            class="btn btn-outline-secondary"
                            onclick="togglePassword('reset_password_form_password_first', this)"
                            title="Afficher/Masquer le mot de passe">
                        👁
                    </button>
                </div>

                {% if form_errors(form.password.first) %}
                    <div class="alert-error">{{ form_errors(form.password.first) }}</div>
                {% endif %}
                {# {{ form_errors(form.password.first) }} #}
            </div>

            <div class="form-field mt-3">
                <div class="label-reset-password">
                    {{ form_label(form.password.second) }}
                </div>

                <div class="input-group input-group-password">
                    {{ form_widget(form.password.second) }}
                    <button type="button"
                            class="btn btn-outline-secondary"
                            onclick="togglePassword('reset_password_form_password_second', this)"
                            title="Afficher/Masquer le mot de passe">
                        👁
                    </button>
                </div>

                {{ form_errors(form.password.second) }}
            </div>

            <div class="field-hint mt-2 mb-3 label-reset-password">
                🔒 12 caractères minimum — majuscule, minuscule, chiffre et caractère spécial requis.
            </div>

            <button type="submit" class="btn-login w-100 mt-2">
                Enregistrer le nouveau mot de passe
            </button>

        {{ form_end(form) }}

        <div class="text-center mt-4">
            <a href="{{ path('app_login') }}" class="lien-swtich-auth">← Retour à la connexion</a>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
    <script src="{{ asset('js/login.js') }}"></script>
{% endblock %}