{% extends 'base.html.twig' %}

{% block title %}Réinitialiser le mot de passe — {{ coordinator.user.firstname }} {{ coordinator.user.lastname }}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/rooms.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/classes.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid px-4 py-3 mt-3">

    {# ---- Header ---- #}
    <div class="dashboard-header">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge-admin">Administrateur</span>
                </div>
                <div class="d-flex align-items-center gap-2 mb-1">
                    <a href="{{ path('app_admin_dashboard') }}" class="breadcrumb-link">Dashboard</a>
                    <span class="breadcrumb-sep">›</span>
                    <span class="breadcrumb-current">Réinitialiser mot de passe</span>
                </div>
                <h1>Réinitialiser le mot de passe</h1>
                <p>
                    Coordinateur : <strong>
                        {{ coordinator.user.firstname }} {{ coordinator.user.lastname }}
                    </strong>
                    — {{ coordinator.user.email }}
                </p>
            </div>
        </div>
    </div>

    {# ---- Formulaire ---- #}
    <div class="row justify-content-center">
        <div class="col-lg-5 mt-4">
            <div class="form-card shadow">

                {{ form_start(form) }}

                    <div class="form-field">
                        {{ form_label(form.password.first) }}
                        {{ form_widget(form.password.first) }}
                        {{ form_errors(form.password.first) }}
                    </div>

                    <div class="form-field">
                        {{ form_label(form.password.second) }}
                        {{ form_widget(form.password.second) }}
                        {{ form_errors(form.password.second) }}
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn-action-primary flex-fill text-center">
                            🔑 Réinitialiser
                        </button>
                        
                        <a href="{{ path('app_admin_dashboard') }}"
                            class="btn-action-secondary flex-fill text-center text-decoration-none">
                            Annuler
                        </a>
                    </div>

                {{ form_end(form) }}

            </div>

            <div class="form-note mt-5">
                 Le nouveau mot de passe sera actif immédiatement. Communiquez-le au coordinateur de façon sécurisée.
            </div>
        </div>
    </div>


</div>
{% endblock %}
