{% extends 'base.html.twig' %}

{% block title %}Salles & Disponibilités — Admin RoomBooking{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/rooms.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid px-4 py-3 mt-3">

    {# ---- Header ---- #}
    <div class="dashboard-header">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge-admin">Administrateur</span>
                </div> 
                <div class="d-flex align-items-center gap-2 mb-1">
                    <a href="{{ path('app_admin_dashboard') }}" class="breadcrumb-link">Dashboard</a>
                    <span class="breadcrumb-sep">›</span>
                    <span class="breadcrumb-current">Salles</span>
                </div>
                <h1>Salles & Disponibilités</h1>
                <p>{{ roomsWithStats|length }} salle{{ roomsWithStats|length > 1 ? 's' : '' }} enregistrée{{ roomsWithStats|length > 1 ? 's' : '' }}</p>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path('app_admin_room_new') }}" class="btn-action-primary text-decoration-none d-inline">
                    + Créer une salle
                </a>
            </div>
        </div>
    </div>

    {{ include('admin/rooms/_filter_rooms.html.twig')}}

    {# ---- Tableau des salles ---- #}
    <div class="reservations-table details shadow">
        <table class="table table-borderless mb-0">
            <thead>
                <tr>
                    <th class="text-center">Salle</th>
                    <th class="text-center">Capacité</th>
                    <th class="text-center">Statut actuel</th>
                    <th class="text-center">Prochaine réservation</th>
                    <th class="text-center">Total réservations</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% if roomsWithStats is empty %}
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            Aucune salle enregistrée.
                        </td>
                    </tr>
                {% else %}
                    {% for item in roomsWithStats %}
                        {% set isFiltered = filterStart and filteredRooms is not null and item.room in filteredRooms %}
                        <tr onclick="window.location='{{ path('app_admin_room_show', {id: item.room.id}) }}'" class="{{ isFiltered ? 'row-available-highlight' : '' }}">
                        
                        {# style="cursor: pointer; #}
                            {# Nom + équipements #}
                            <td>
                                <div class="room-row-name">{{ item.room.name }}</div>

                                {% if item.room.equipments is not empty %}
                                    <div class="room-row-equip">

                                        {% for equip in item.room.equipments %}
                                            <span class="equipment-tag">{{ equip.name }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </td>

                            {# Capacité #}
                            <td>
                                <span class="room-capacity-badge">👥 {{ item.room.capacity }}</span>
                            </td>

                            {# Statut actuel #}
                            <td>
                                {% if item.status == 'occupied' %}

                                    <span class="status-badge d-inline status-occupied">🔴 Occupée</span>
                                    
                                    {% if item.currentReservation %}

                                        <div class="status-detail">
                                            jusqu'à {{ item.currentReservation.reservationEnd|date('H:i') }}
                                            — {{ item.currentReservation.user.firstname }} {{ item.currentReservation.user.lastname }}
                                        </div>
                                    {% endif %}

                                {% else %}
                                    <span class="status-badge status-available">🟢 Disponible</span>
                                {% endif %}
                            </td>

                            {# Prochaine réservation #}
                            <td class="text-center">
                                {% if item.nextReservation %}

                                    <div class="next-res-date">{{ item.nextReservation.reservationStart|date('d/m/Y') }}</div>
                                    <div class="next-res-time">
                                        {{ item.nextReservation.reservationStart|date('H:i') }}
                                        → {{ item.nextReservation.reservationEnd|date('H:i') }}
                                    </div>
                                    <div class="next-res-user">
                                        {{ item.nextReservation.user.firstname }} {{ item.nextReservation.user.lastname }}
                                    </div>
                                {% else %}
                                    <span class="text-muted-next-res small">Aucune</span>
                                {% endif %}
                            </td>

                            {# Total réservations #} 
                            <td class="text-center">
                                <span class="total-res-badge">{{ item.totalReservations }}</span>
                            </td>

                            {# Actions #}
                            <td onclick="event.stopPropagation()">
                                <div class="d-flex gap-2 flex-wrap">
                                    <a href="{{ path('app_admin_room_show', {id: item.room.id}) }}"
                                       class="btn-action-secondary btn-sm-action text-decoration-none" title="Voir le détail">
                                        <span class="action-icon-dispo d-flex align-items-center justify-content-center">👁</span>
                                    </a>

                                    <a href="{{ path('app_admin_room_edit', {id: item.room.id}) }}"
                                       class="btn-action-secondary btn-sm-action text-decoration-none" title="Modifier">
                                        <span class="action-icon-dispo d-flex align-items-center justify-content-center">✏️</span>
                                    </a>

                                    {# Tâche 18 : réserver #}
                                    <a href="{{ path('app_admin_reservation_new', {room: item.room.id}) }}"
                                       class="btn-action-primary btn-sm-action text-decoration-none" title="Réserver cette salle">
                                        <span class="action-icon-dispo d-flex align-items-center justify-content-center">📅</span>
                                    </a>

                                    {{ include('partials/_delete_room.html.twig', { room: item.room }) }}
                                </div>
                            </td>

                        </tr>
                    {% endfor %}
                {% endif %}
            </tbody>
        </table>
    </div>

</div>
{% endblock %}
