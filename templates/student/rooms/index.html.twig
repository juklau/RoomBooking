{% extends 'base.html.twig' %}

{% block title %}Salles & Disponibilités — Étudiant RoomBooking{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/rooms.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/student.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid px-4 py-3 mt-3">

    {# ---- Header ---- #}
    <div class="dashboard-header">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="badge-student">Étudiant</span>
                </div>
                <div class="d-flex align-items-center gap-2 mb-1">
                    <a href="{{ path('app_student_dashboard') }}" class="breadcrumb-link-student">Dashboard</a>
                    <span class="breadcrumb-sep">›</span>

                    <span class="breadcrumb-current">Salles</span>
                </div>
                <h1>Salles & Disponibilités</h1>
                <p>{{ roomsWithStats|length }} salle{{ roomsWithStats|length > 1 ? 's' : '' }} enregistrée{{ roomsWithStats|length > 1 ? 's' : '' }}</p>
            </div>
            <div class="d-flex gap-2">
            {#  #}
                <a href="{{ path('app_student_reservation_new') }}" class="btn-student-outline text-decoration-none d-inline">
                    Réserver une salle
                </a>
            </div>
        </div>
    </div>

    {{ include('student/rooms/_filter_rooms.html.twig')}}

    {# ---- Tableau des salles ---- #}
    <div class="reservations-table details shadow">
        <table class="table table-borderless mb-0">
            <thead>
                <tr>
                    <th class="text-center">Salle</th>
                    <th class="text-center">Capacité</th>
                    <th class="text-center">Statut actuel</th>
                    <th class="text-center">Ma prochaine réservation</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% if roomsWithStats is empty %}
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            Aucune salle enregistrée.
                        </td>
                    </tr>
                {% else %}
                    {% for item in roomsWithStats %}
                        {% set isFiltered = filterStart and filteredRooms is not null and item.room in filteredRooms %}
                        <tr onclick="window.location='{{ path('app_student_room_show', {id: item.room.id}) }}'" class="{{ isFiltered ? 'row-available-highlight' : '' }} rows-onclick">
                      
                            {#  #}
                            {# style="cursor: pointer;" #}

                            {# Nom + équipements #}
                            <td>
                                <div class="room-row-name text-black">{{ item.room.name }}</div>

                                {% if item.room.equipments is not empty %}
                                    <div class="room-row-equip">

                                        {% for equip in item.room.equipments %}
                                            <span class="equipment-tag">{{ equip.name }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            </td>

                            {# Capacité #}
                            <td class="text-center">
                                <span class="room-capacity-badge">👥 {{ item.room.capacity }}</span>
                            </td>

                            {# Statut actuel #}
                            <td class="text-center">
                                {% if item.status == 'occupied' %}

                                    <span class="status-badge d-inline status-occupied">🔴 Occupée</span>
                                    
                                    {% if item.currentReservation %}

                                        <div class="status-detail">
                                            jusqu'à {{ item.currentReservation.reservationEnd|date('H:i', 'Europe/Paris') }}
                                        </div>
                                    {% endif %}

                                {% else %}
                                    <span class="status-badge status-available">🟢 Disponible</span>
                                {% endif %}
                            </td>

                            {# Ma Prochaine réservation sur cette salle #}
                            <td class="text-center">
                                {% if item.nextReservation %}

                                    <div class="next-res-date">{{ item.nextReservation.reservationStart|date('d/m/Y', 'Europe/Paris') }}</div>
                                    <div class="next-res-time">
                                        {{ item.nextReservation.reservationStart|date('H:i', 'Europe/Paris') }}
                                        → {{ item.nextReservation.reservationEnd|date('H:i', 'Europe/Paris') }}
                                    </div>
                                {% else %}
                                    <span class="text-muted-next-res small">Aucune</span>
                                {% endif %}
                            </td>

                            {# Actions #}
                            <td onclick="event.stopPropagation()">
                                <div class="d-flex gap-4 justify-content-center">

                                    {# {{ path('app_student_room_show', {id: item.room.id}) }} #}
                                    <a href="{{ path('app_student_room_show', {id: item.room.id}) }}"
                                       class="btn-action-secondary student btn-sm-action text-decoration-none" title="Voir le détail">
                                        <span class="action-icon-dispo d-flex align-items-center justify-content-center">👁</span>
                                    </a>

                                    {# réserver #}
                                    <a href="{{ path('app_student_reservation_new', {room: item.room.id}) }}"
                                       class="btn-student btn-sm-action text-decoration-none" title="Réserver cette salle">
                                        <span class="action-icon-dispo d-flex align-items-center justify-content-center">📅</span>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                {% endif %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
