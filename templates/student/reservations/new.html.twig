{% extends 'base.html.twig' %}

{% block title %}Créer une réservation — Étudiant RoomBooking{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/rooms.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/student.css') }}">
{% endblock %}

{% block body %}
<div class="container-fluid px-4 py-3 mt-3">

    {# ---- Header ---- #}
    <div class="dashboard-header">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="badge-student">Étudiant</span>
                </div>
                <div class="d-flex align-items-center gap-2 mb-1">
                    <a href="{{ path('app_student_dashboard') }}" class="breadcrumb-link-student">Dashboard</a>
                    <span class="breadcrumb-sep">›</span>

                    <a href="{{ path('app_student_rooms') }}" class="breadcrumb-link-student">Salles</a>
                    <span class="breadcrumb-sep">›</span>

                    <span class="breadcrumb-current">Nouvelle réservation</span>
                </div>
                <h1>Réserver une salle</h1>
            </div>
        </div>
    </div>

    {# ---- Formulaire ---- #}
    <div class="row justify-content-center">
        <div class="col-lg-6 mt-3">
            <div class="form-card shadow">

                {{ form_start(form) }}

                {# marquer classe comme rendu pour éviter le rendu automatique par form_end #}
                {% do form.classe.setRendered() %}

                    {# Salle #}
                    <div class="form-field">
                        {{ form_label(form.room) }}
                        {{ form_widget(form.room) }}
                        {{ form_errors(form.room) }}
                    </div>

                    {# Date #}
                    <div class="form-field">
                        {{ form_label(form.date) }}
                        {{ form_widget(form.date) }}
                        {{ form_errors(form.date) }}
                    </div>

                    {# Heures de début et fin #}
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-field">
                                {{ form_label(form.startTime) }}
                                {{ form_widget(form.startTime) }}
                                {{ form_errors(form.startTime) }} 
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-field">
                                {{ form_label(form.endTime) }}
                                {{ form_widget(form.endTime) }}
                                {{ form_errors(form.endTime) }}
                            </div>
                        </div>
                    </div>

                    <div class="field-hint mb-4 text-center label-available">
                        🕐 Créneaux disponibles de 08:00 à 20:00, par intervalles de 30 minutes.
                    </div>

                     {# Classe #}
                  
                    {# Classe — affichage fixe, pas de select #}
                    <div class="form-field">
                        <label>Classe concernée</label>
                        <input type="text" 
                            class="form-control" 
                            value="{{ studentClasse ? studentClasse.name : 'Aucune classe assignée' }}" 
                            disabled>
                        {# champ caché pour soumettre la valeur #}
                        {% if studentClasse %}
                            <input type="hidden" name="student_reservation[classe]" value="{{ studentClasse.id }}">
                        {% endif %}
                    </div>
                    {# Boutons #}
                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn-student-details flex-fill text-center">
                             Réserver
                        </button>
                        <a href="{{ path('app_student_rooms') }}"
                           class="btn-action-secondary flex-fill text-center text-decoration-none">
                            Annuler
                        </a>
                    </div>

                {{ form_end(form) }}

            </div>

            <div class="form-note mt-4">
                Trois vérifications sont effectuées automatiquement :
                la date doit être dans le futur, l'heure de fin doit être après l'heure de début,
                et la salle doit être libre sur ce créneau.
            </div>
        </div>
    </div>

</div>
{% endblock %}
